<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Deep Understander · Cognitive Profile Assessment · Extended</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet">
<style>
:root {
  --navy:#1B3A5C; --steel:#2E6DA4; --lblue:#E4EEF8; --dblue:#163050;
  --amber:#A05800; --lamber:#FDF4E3; --damber:#7A4000;
  --green:#276245; --lgreen:#E2F0E9;
  --red:#9E2B1A; --lred:#FAEAE7;
  --cream:#FAFAF6; --offwhite:#F4F2ED;
  --dgrey:#3A3A3A; --mgrey:#888; --lgrey:#E5E3DD; --xgrey:#CCC9C2;
  --white:#fff;
  --font-display:'Playfair Display',Georgia,serif;
  --font-body:'DM Sans',system-ui,sans-serif;
  --radius:8px; --shadow:0 2px 16px rgba(0,0,0,0.07);
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:var(--font-body);background:var(--cream);color:var(--dgrey);min-height:100vh;font-size:16px;line-height:1.6}

/* ── PROGRESS ── */
#progressBar{position:fixed;top:0;left:0;right:0;height:3px;background:var(--lgrey);z-index:200}
#progressFill{height:100%;background:var(--steel);transition:width .6s ease;width:0%}

/* ── NAV ── */
nav{position:fixed;top:3px;left:0;right:0;background:rgba(250,250,246,.96);backdrop-filter:blur(10px);border-bottom:1px solid var(--lgrey);padding:13px 44px;display:flex;align-items:center;justify-content:space-between;z-index:199}
.nav-brand{font-family:var(--font-display);font-size:1.05rem;font-weight:600;color:var(--navy);letter-spacing:-.01em}
.nav-right{display:flex;align-items:center;gap:20px}
.nav-step{font-size:.72rem;color:var(--mgrey);font-weight:500;letter-spacing:.08em;text-transform:uppercase}
.nav-save-badge{font-size:.72rem;font-weight:600;color:var(--green);letter-spacing:.04em;opacity:0;transition:opacity .3s;background:var(--lgreen);padding:3px 10px;border-radius:12px}
.nav-save-badge.show{opacity:1}

/* ── SECTIONS ── */
.section{display:none;min-height:100vh;padding:96px 44px 80px;max-width:860px;margin:0 auto}
.section.active{display:block}
#cover,#resume{display:none;min-height:100vh;padding:0 44px;max-width:860px;margin:0 auto;flex-direction:column;justify-content:center}
#cover.active,#resume.active{display:flex}
#generating{display:none;align-items:center;justify-content:center;min-height:100vh;flex-direction:column;gap:20px;text-align:center;padding:0 44px;max-width:860px;margin:0 auto}
#generating.active{display:flex}
#report.active{display:block;padding:96px 44px 80px;max-width:860px;margin:0 auto}

/* ── COVER ── */
.cover-tag{font-size:.7rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--steel);margin-bottom:18px}
.cover-h1{font-family:var(--font-display);font-size:clamp(2.4rem,5vw,3.6rem);line-height:1.12;font-weight:700;color:var(--navy);margin-bottom:8px}
.cover-h1 em{font-style:italic;color:var(--steel)}
.cover-sub{font-size:1.05rem;color:var(--mgrey);font-weight:300;margin-bottom:36px;max-width:560px;line-height:1.65}
.cover-meta{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:40px}
.cover-chip{display:flex;align-items:center;gap:8px;padding:7px 14px;border:1px solid var(--lgrey);border-radius:20px;font-size:.83rem;color:var(--dgrey);background:var(--white)}
.cover-chip-dot{width:7px;height:7px;border-radius:50%;background:var(--steel);flex-shrink:0}
.child-field{margin-bottom:32px;max-width:360px}
.child-field label{display:block;font-size:.75rem;font-weight:700;letter-spacing:.09em;text-transform:uppercase;color:var(--navy);margin-bottom:9px}
.child-field input{width:100%;padding:13px 17px;border:1.5px solid var(--xgrey);border-radius:6px;background:var(--white);font-family:var(--font-body);font-size:1rem;color:var(--dgrey);outline:none;transition:border-color .2s}
.child-field input:focus{border-color:var(--steel)}

/* ── RESUME SCREEN ── */
.resume-card{background:var(--white);border:1px solid var(--lgrey);border-radius:var(--radius);padding:40px;max-width:520px;box-shadow:var(--shadow)}
.resume-tag{font-size:.7rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--amber);margin-bottom:12px}
.resume-h{font-family:var(--font-display);font-size:1.7rem;font-weight:700;color:var(--navy);margin-bottom:10px}
.resume-sub{font-size:.93rem;color:var(--mgrey);margin-bottom:28px;line-height:1.6}
.resume-progress{margin-bottom:28px}
.resume-prog-label{font-size:.75rem;font-weight:600;color:var(--dgrey);margin-bottom:8px;letter-spacing:.04em}
.resume-acts{display:flex;flex-direction:column;gap:6px;margin-bottom:4px}
.resume-act{display:flex;align-items:center;gap:10px;font-size:.88rem}
.resume-act-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}
.resume-act-dot.done{background:var(--green)}
.resume-act-dot.current{background:var(--amber)}
.resume-act-dot.todo{background:var(--lgrey)}
.resume-act.done-act{color:var(--mgrey)}
.resume-act.current-act{color:var(--navy);font-weight:600}
.resume-btn-row{display:flex;gap:12px;flex-wrap:wrap}

/* ── BUTTONS ── */
.btn-primary{display:inline-flex;align-items:center;gap:9px;background:var(--navy);color:var(--white);font-family:var(--font-body);font-size:.93rem;font-weight:600;padding:15px 34px;border-radius:6px;border:none;cursor:pointer;transition:background .2s,transform .12s;letter-spacing:.01em}
.btn-primary:hover{background:var(--steel);transform:translateY(-1px)}
.btn-secondary{display:inline-flex;align-items:center;gap:8px;background:transparent;color:var(--navy);font-family:var(--font-body);font-size:.88rem;font-weight:500;padding:11px 22px;border-radius:6px;border:1.5px solid var(--xgrey);cursor:pointer;transition:border-color .2s,background .2s}
.btn-secondary:hover{border-color:var(--navy);background:var(--offwhite)}
.btn-danger{display:inline-flex;align-items:center;gap:8px;background:transparent;color:var(--mgrey);font-family:var(--font-body);font-size:.83rem;font-weight:400;padding:8px 0;border:none;cursor:pointer;text-decoration:underline;text-underline-offset:3px}
.btn-row{display:flex;gap:14px;align-items:center;margin-top:36px;flex-wrap:wrap}

/* ── ACTIVITY HEADER ── */
.act-header{margin-bottom:32px;padding-bottom:22px;border-bottom:1px solid var(--lgrey)}
.act-num{font-size:.7rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--steel);margin-bottom:10px;display:flex;align-items:center;gap:10px}
.act-num-pip{width:20px;height:20px;border-radius:50%;background:var(--steel);color:var(--white);font-size:.7rem;font-weight:700;display:flex;align-items:center;justify-content:center}
.act-title{font-family:var(--font-display);font-size:1.9rem;font-weight:700;color:var(--navy);line-height:1.18;margin-bottom:7px}
.act-desc{font-size:.93rem;color:var(--mgrey);font-weight:300;line-height:1.65;max-width:620px}

/* ── CONTENT BLOCKS ── */
.setup-box{background:var(--offwhite);border:1px solid var(--lgrey);border-radius:var(--radius);padding:26px 30px;margin-bottom:28px}
.setup-box h3,.box-label{font-size:.68rem;font-weight:700;letter-spacing:.11em;text-transform:uppercase;color:var(--steel);margin-bottom:14px}
.setup-items{display:flex;flex-direction:column;gap:11px}
.setup-item{display:flex;gap:13px;align-items:flex-start}
.setup-num{width:23px;height:23px;border-radius:50%;background:var(--navy);color:var(--white);font-size:.72rem;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px}
.setup-text{font-size:.9rem;line-height:1.55;color:var(--dgrey)}
.setup-text strong{color:var(--navy);font-weight:600}

.instr-block{margin-bottom:26px}
.instr-block h3{font-size:.68rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--navy);margin-bottom:12px}
.instr-block p{font-size:.92rem;line-height:1.7;color:var(--dgrey);margin-bottom:9px}

.script{background:var(--white);border-left:3px solid var(--steel);padding:14px 18px;border-radius:0 6px 6px 0;margin:12px 0;font-style:italic;font-size:.92rem;line-height:1.65;color:var(--dgrey)}

.warn-box{background:var(--lred);border:1px solid rgba(158,43,26,.18);border-radius:6px;padding:14px 18px;margin-bottom:22px;font-size:.86rem;line-height:1.6;color:var(--red)}
.warn-box strong{display:block;margin-bottom:3px;font-weight:700}
.note-box{background:var(--lamber);border:1px solid rgba(160,88,0,.18);border-radius:6px;padding:14px 18px;margin-bottom:22px;font-size:.86rem;line-height:1.6;color:var(--amber)}
.note-box strong{font-weight:700}
.info-box{background:var(--lblue);border:1px solid rgba(46,109,164,.18);border-radius:6px;padding:14px 18px;margin-bottom:22px;font-size:.86rem;line-height:1.6;color:var(--navy)}
.info-box strong{font-weight:700}

/* Phase cards */
.phase-cards{display:flex;flex-direction:column;gap:13px;margin-bottom:26px}
.phase-card{border:1px solid var(--lgrey);border-radius:var(--radius);overflow:hidden}
.phase-card-head{padding:13px 18px;display:flex;align-items:center;gap:13px}
.phase-icon{width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.8rem;font-weight:700;color:var(--white);flex-shrink:0}
.phase-card-title{font-weight:600;font-size:.92rem;color:var(--navy)}
.phase-card-body{padding:2px 18px 14px 65px;font-size:.88rem;line-height:1.6;color:var(--dgrey)}

/* Story cards */
.story-cards{display:flex;flex-direction:column;gap:12px;margin-bottom:26px}
.story-card{background:var(--white);border:1px solid var(--lgrey);border-radius:var(--radius);overflow:hidden}
.story-card-head{padding:11px 16px;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--lgrey);background:var(--offwhite)}
.story-label{font-size:.72rem;font-weight:700;color:var(--mgrey);letter-spacing:.06em;text-transform:uppercase}
.story-ans{font-size:.72rem;font-weight:700;color:var(--green)}
.story-card-body{padding:13px 16px}
.story-text{font-style:italic;font-size:.92rem;line-height:1.6;margin-bottom:7px;color:var(--dgrey)}
.story-watch{font-size:.81rem;color:var(--mgrey);line-height:1.5}

/* ── OBS FORM ── */
.obs-section{margin-bottom:36px;padding-bottom:32px;border-bottom:1px solid var(--lgrey)}
.obs-section:last-of-type{border-bottom:none}
.obs-section-title{font-family:var(--font-display);font-size:1.15rem;font-weight:600;color:var(--navy);margin-bottom:5px}
.obs-section-sub{font-size:.83rem;color:var(--mgrey);margin-bottom:22px;line-height:1.5}

.obs-q{margin-bottom:26px}
.obs-q label{display:block;font-size:.91rem;font-weight:500;color:var(--dgrey);line-height:1.6;margin-bottom:13px}
.obs-q label .qn{font-weight:700;color:var(--steel);margin-right:3px}

.radio-opts{display:flex;flex-direction:column;gap:9px}
.radio-opt{display:flex;align-items:flex-start;gap:11px;padding:12px 16px;border:1.5px solid var(--lgrey);border-radius:6px;cursor:pointer;transition:border-color .15s,background .15s;background:var(--white)}
.radio-opt:hover{border-color:var(--steel);background:var(--lblue)}
.radio-opt.selected{border-color:var(--steel);background:var(--lblue)}
.radio-opt input{display:none}
.rdot{width:17px;height:17px;border-radius:50%;border:2px solid var(--xgrey);flex-shrink:0;margin-top:3px;transition:border-color .15s,background .15s;display:flex;align-items:center;justify-content:center}
.radio-opt.selected .rdot{border-color:var(--steel);background:var(--steel)}
.rdot::after{content:'';width:5px;height:5px;border-radius:50%;background:var(--white);opacity:0;transition:opacity .15s}
.radio-opt.selected .rdot::after{opacity:1}
.rtext{font-size:.9rem;line-height:1.5;color:var(--dgrey)}
.rtext .rl{font-weight:600;color:var(--navy);display:block;margin-bottom:2px}
.rtext .rd{font-size:.82rem;color:var(--mgrey)}

.obs-ta{width:100%;padding:13px 16px;border:1.5px solid var(--lgrey);border-radius:6px;background:var(--white);font-family:var(--font-body);font-size:.9rem;line-height:1.6;color:var(--dgrey);resize:vertical;min-height:85px;outline:none;transition:border-color .2s}
.obs-ta:focus{border-color:var(--steel)}

.val-msg{font-size:.8rem;color:var(--red);margin-top:5px;display:none}
.obs-q.error .val-msg{display:block}
.obs-q.error .radio-opts,.obs-q.error .obs-ta{outline:1.5px solid var(--red);border-radius:6px}

/* ── SAVE TOAST ── */
#saveToast{position:fixed;bottom:90px;left:50%;transform:translateX(-50%) translateY(10px);background:var(--navy);color:var(--white);padding:10px 22px;border-radius:20px;font-size:.85rem;font-weight:500;opacity:0;transition:opacity .3s,transform .3s;pointer-events:none;z-index:300;white-space:nowrap}
#saveToast.show{opacity:1;transform:translateX(-50%) translateY(0)}

/* ── STICKY BOTTOM NAV ── */
.sticky-foot{position:fixed;bottom:0;left:0;right:0;background:rgba(250,250,246,.97);backdrop-filter:blur(8px);border-top:1px solid var(--lgrey);padding:14px 44px;display:flex;justify-content:space-between;align-items:center;z-index:199}
.sticky-foot-info{font-size:.8rem;color:var(--mgrey)}

/* ── GENERATING ── */
.gen-spinner{width:46px;height:46px;border:3px solid var(--lgrey);border-top-color:var(--steel);border-radius:50%;animation:spin .85s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.gen-title{font-family:var(--font-display);font-size:1.7rem;color:var(--navy)}
.gen-sub{font-size:.92rem;color:var(--mgrey);max-width:380px;line-height:1.6}
.gen-steps{display:flex;flex-direction:column;gap:7px;margin-top:6px;text-align:left}
.gen-step{font-size:.83rem;color:var(--mgrey);opacity:0;transform:translateY(6px);transition:opacity .4s,transform .4s}
.gen-step.vis{opacity:1;transform:translateY(0)}

/* ── REPORT ── */
.report-hero{background:var(--navy);border-radius:12px;padding:44px;margin-bottom:36px;position:relative;overflow:hidden}
.report-hero::before{content:'';position:absolute;top:-70px;right:-70px;width:260px;height:260px;border-radius:50%;background:rgba(255,255,255,.04)}
.report-hero::after{content:'';position:absolute;bottom:-50px;left:50px;width:180px;height:180px;border-radius:50%;background:rgba(255,255,255,.03)}
.rh-tag{font-size:.7rem;font-weight:700;letter-spacing:.11em;text-transform:uppercase;color:rgba(255,255,255,.45);margin-bottom:9px}
.rh-type{font-family:var(--font-display);font-size:2rem;font-weight:700;color:var(--white);line-height:1.18;margin-bottom:10px}
.rh-type em{font-style:italic;opacity:.85}
.rh-conf{font-size:.85rem;color:rgba(255,255,255,.55);margin-bottom:24px}
.rh-pills{display:flex;flex-wrap:wrap;gap:8px}
.rpill{padding:5px 13px;border-radius:16px;font-size:.75rem;font-weight:600;letter-spacing:.02em}
.rpill-s2{background:rgba(46,109,164,.3);color:rgba(255,255,255,.85)}
.rpill-s1{background:rgba(39,98,69,.35);color:rgba(255,255,255,.85)}
.rpill-mx{background:rgba(160,88,0,.3);color:rgba(255,255,255,.85)}

.report-body{font-size:.95rem;line-height:1.75;color:var(--dgrey)}
.report-body h2{font-family:var(--font-display);font-size:1.3rem;font-weight:600;color:var(--navy);margin:32px 0 12px}
.report-body h3{font-size:.68rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--steel);margin:24px 0 9px}
.report-body p{margin-bottom:13px}
.report-body ul{padding-left:18px;margin-bottom:13px}
.report-body li{margin-bottom:7px}
.report-body strong{color:var(--navy);font-weight:600}

.act-result-card{border:1px solid var(--lgrey);border-radius:var(--radius);overflow:hidden;margin-bottom:12px}
.arc-head{padding:11px 16px;background:var(--offwhite);border-bottom:1px solid var(--lgrey);display:flex;justify-content:space-between;align-items:center}
.arc-title{font-weight:600;font-size:.86rem;color:var(--navy)}
.arc-badge{font-size:.68rem;font-weight:700;padding:3px 9px;border-radius:11px;letter-spacing:.04em;text-transform:uppercase}
.arc-s2{background:var(--lblue);color:var(--steel)}
.arc-s1{background:var(--lgreen);color:var(--green)}
.arc-mx{background:var(--lamber);color:var(--amber)}
.arc-body{padding:13px 16px;font-size:.88rem;line-height:1.6;color:var(--dgrey)}

/* Upsell */
.upsell{background:linear-gradient(135deg,var(--navy) 0%,#2a4f7a 100%);border-radius:12px;padding:44px;margin-top:44px;color:var(--white);position:relative;overflow:hidden}
.upsell::before{content:'';position:absolute;top:-80px;right:-40px;width:280px;height:280px;border-radius:50%;background:rgba(255,255,255,.04)}
.upsell-tag{font-size:.68rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.45);margin-bottom:12px}
.upsell-title{font-family:var(--font-display);font-size:1.65rem;font-weight:700;line-height:1.22;margin-bottom:12px}
.upsell-desc{font-size:.92rem;line-height:1.7;color:rgba(255,255,255,.72);max-width:520px;margin-bottom:28px}
.upsell-feats{display:flex;flex-direction:column;gap:9px;margin-bottom:32px}
.upsell-feat{display:flex;gap:11px;align-items:flex-start;font-size:.88rem;color:rgba(255,255,255,.78);line-height:1.5}
.ucheck{width:19px;height:19px;border-radius:50%;background:rgba(255,255,255,.14);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:.62rem;font-weight:700;color:var(--white);margin-top:1px}
.upsell-price-row{display:flex;align-items:baseline;gap:9px;margin-bottom:22px}
.upsell-price{font-family:var(--font-display);font-size:2.3rem;font-weight:700;color:var(--white)}
.upsell-price-sub{font-size:.86rem;color:rgba(255,255,255,.45)}
.btn-upsell{display:inline-flex;align-items:center;gap:9px;background:var(--white);color:var(--navy);font-family:var(--font-body);font-size:.95rem;font-weight:700;padding:17px 38px;border-radius:6px;border:none;cursor:pointer;transition:transform .14s,box-shadow .14s;letter-spacing:.01em}
.btn-upsell:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(0,0,0,.22)}
.upsell-note{margin-top:14px;font-size:.75rem;color:rgba(255,255,255,.3)}

/* ── RESPONSIVE ── */
@media(max-width:620px){
  .section,#cover,#resume,#generating{padding-left:20px;padding-right:20px}
  nav{padding:11px 20px}
  .sticky-foot{padding:13px 20px}
  .report-hero,.upsell{padding:28px 24px}
}
</style>
</head>
<body>

<div id="progressBar"><div id="progressFill"></div></div>
<div id="saveToast">Progress saved ✓</div>

<nav>
  <div class="nav-brand">[ Brand ] · Diagnostic</div>
  <div class="nav-right">
    <div class="nav-step" id="navStep"></div>
    <div class="nav-save-badge" id="saveBadge">Saved ✓</div>
  </div>
</nav>

<!-- ══════════════════════════════════════════════════════ COVER -->
<div id="cover" class="active">
  <div style="padding-top:80px">
    <div class="cover-tag">Cognitive Profile Assessment · Years 4–5 · Extended</div>
    <h1 class="cover-h1">Is <span id="coverName">your child</span> a<br><em>Deep Understander?</em></h1>
    <p class="cover-sub">Calibrated for above-average Year 4 children (age 8–9). A guided home assessment across 6 activities that identifies how your child approaches problems — and whether their preparation for selective entry is matched to how they actually think.</p>
    <div class="cover-meta">
      <div class="cover-chip"><div class="cover-chip-dot"></div>6 short activities</div>
      <div class="cover-chip"><div class="cover-chip-dot"></div>Suited to above-average Year 4 and high-ability Year 3</div>
      <div class="cover-chip"><div class="cover-chip-dot"></div>~35 minutes total</div>
      <div class="cover-chip"><div class="cover-chip-dot"></div>Progress saved — complete across multiple visits</div>
      <div class="cover-chip"><div class="cover-chip-dot"></div>Personalised report generated instantly</div>
    </div>
    <div class="child-field">
      <label for="childInput">Your child's first name</label>
      <input type="text" id="childInput" placeholder="e.g. Priya" maxlength="40" autocomplete="off">
    </div>
    <div class="warn-box">
      <strong>Before you begin</strong>
      Do not show approval or disapproval during any activity. Keep a neutral expression throughout — your reactions will change what your child does. Read each activity's instructions fully before sitting down with your child.
    </div>
    <button class="btn-primary" onclick="startAssessment()">Begin Assessment →</button>
  </div>
</div>

<!-- ══════════════════════════════════════════════════════ RESUME -->
<div id="resume">
  <div style="padding-top:80px">
    <div class="resume-card">
      <div class="resume-tag">Welcome back</div>
      <h2 class="resume-h" id="resumeH">Continue assessment</h2>
      <p class="resume-sub" id="resumeSub">You've made a start. Pick up exactly where you left off below.</p>
      <div class="resume-progress">
        <div class="resume-prog-label">YOUR PROGRESS</div>
