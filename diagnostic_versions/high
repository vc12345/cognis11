    q1b:{a:'did not make an error',b:'made an error and immediately self-corrected',c:'made an error and only noticed when pointed out',d:'made an error and did not notice at all'},
    q1c:{a:'asked about the ambiguous square before placing it',b:'placed the square confidently without comment',c:'placed it then changed their mind',d:'did not notice it was ambiguous'},
    q1d:{a:'action-oriented — just applied rules without questioning',b:'asked why the rule changed before proceeding',c:'repeated the rule back to themselves before acting',d:'seemed mildly frustrated by rule changes'},
    q2a:{a:'correctly subtracted to get 4 (constructed the situation)',b:'added to get 14 (surface pattern-matched)',c:'said 14 first then self-corrected to 4',d:'paused a long time then got it right',e:'got a different wrong answer or did not answer'},
    q2b:{a:'completed both steps correctly',b:'stopped after first step — answered 8',c:'completed both steps but made an arithmetic error',d:'asked how many steps before answering'},
    q2c:{a:'fast and mostly correct including the reversal',b:'careful and mostly correct throughout',c:'fast on simple stories, slower on complex ones',d:'consistent pace regardless of difficulty'},
    q2d:{a:'did not get any wrong',b:'self-corrected without prompting',c:'accepted wrong answers without questioning',d:'asked to hear the story again'},
    q3a:{a:'consistent throughout — repetition had no negative effect',b:'noticeably slower from around card 10-12',c:'making errors or commenting by card 15+',d:'got faster as repetition continued'},
    q3b:{a:'clear re-engagement on format switch',b:'no change in energy',c:'relieved but not re-engaged',d:'confused by format change'},
    q3c:{a:'simple alternation (A,B,A,B)',b:'simple number sequence',c:'multi-step or growing rule',d:'trick pattern that deliberately breaks','e':'cross-domain mixing numbers and letters',f:'could not or would not make one'},
    q3d:{a:'under 30 seconds',b:'1-2 minutes',c:'close to the full 3 minutes — absorbed'},
    q3e:{a:'said nothing',b:'explained the rule unprompted',c:'asked if you thought it was hard',d:'said it was too easy and wanted to make harder one'},
    q4a:{a:'"I just know" or counted on fingers — no explanation',b:'gave rule label without mechanism',c:'constructed a causal chain explaining why'},
    q4b:{a:'named the rule only',b:'explained step-by-step reasoning',c:'knew the answer but could not explain'},
    q4c:{a:'association-based justification',b:'definitional rule applied',c:'"I don\'t know" or "it just is"',d:'questioned the premise of the question itself'},
    q4d:{a:'indifferent — comfortable not knowing why',b:'visibly uncomfortable when could not explain',c:'started reasoning aloud to construct explanation',d:'was able to explain all answers'},
    q5a:{a:'extensive self-commentary throughout',b:'occasional comments when stuck or when something clicked',c:'mostly silent — concentrated',d:'silent but regularly looked up for reaction'},
    q5b:{a:'tried something immediately — trial and error',b:'paused, looked carefully, then acted',c:'asked for help or asked if doing it right',d:'stepped back to view the whole puzzle before touching anything'},
    q5c:{a:'"I don\'t know, I just did" or a shrug',b:'gave a rule — "I always do edges first"',c:'explained the reasoning behind their strategy',d:'asked you how you would start — reversed the question'},
    q5d:{a:'clear consistent strategy from the start',b:'started with strategy but adapted as went',c:'intuitive throughout — picked up pieces that looked right',d:'constructed a strategy mid-way and switched to it'},
    q6a:{a:'wants to start immediately and learn rules as they go',b:'listens, asks clarifying questions, then starts',c:'wants all rules fully before touching anything',d:'watches others play first before joining'},
    q6b:{a:'accepts majority view and moves on',b:'argues position with reasoning',c:'insists on looking it up to find correct answer',d:'proposes a compromise rule'},
    q6c:{a:'no — prefers existing games',b:'yes — simple rules loosely applied',c:'yes — specific structured rules they expected others to follow',d:'yes — elaborate rules with exceptions and scoring systems'},
    q6d:{a:'moves on — does not dwell on not knowing',b:'asks you immediately',c:'tries to work it out from context before asking',d:'gets bothered by not knowing — persists until they understand'},
    q6e:{a:'accepts corrections easily and moves on',b:'wants to understand WHY they were wrong before accepting',c:'dislikes being wrong — gets frustrated or upset',d:'sometimes argues they were not wrong'},
    q_instinct:{a:'pattern-matching and acting quickly',b:'understanding deeply before acting',c:'both depending on the situation',d:'genuinely unsure'}
  };

  return `Write a personalised cognitive profile for ${n} based on these observations from 6 activities:

ACTIVITY 1 — RULE SWITCH:
Phase 2 response: ${m(maps.q1a, a.q1a)}
