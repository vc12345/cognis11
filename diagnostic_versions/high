Be specific to these observations. Avoid generic statements. Reference actual things that happened.`;
}

// ── SCORE AND RENDER ─────────────────────────────────────────────────────────
function scoreProfile() {
  const a = state.answers;
  let s2 = 0, s1 = 0;
  // Activity 1
  if (a.q1a === 'b') s2 += 2;
  if (a.q1a === 'a') s1 += 2;
  if (a.q1b === 'b') s2++;
  if (a.q1b === 'd') s1 += 2;
  if (a.q1c === 'a') s2 += 2;
  if (['b','d'].includes(a.q1c)) s1++;
  if (['b','c'].includes(a.q1d)) s2++;
  if (a.q1d === 'a') s1++;
  // Activity 2
  if (['a','d'].includes(a.q2a)) s2++;
  if (a.q2a === 'b') s1 += 2;
  if (a.q2a === 'c') s2++;
  if (a.q2b === 'd') s2++;
  if (a.q2b === 'b') s1++;
  if (a.q2c === 'b') s2++;
  if (a.q2c === 'a') s1++;
  if (a.q2d === 'b') s2++;
  if (a.q2d === 'c') s1++;
  // Activity 3
  if (['b','c'].includes(a.q3a)) s2++;
  if (a.q3a === 'd') s1 += 2;
  if (a.q3b === 'a') s2++;
  if (a.q3b === 'b') s1++;
  if (['c','d','e'].includes(a.q3c)) s2 += 2;
  if (['a','b'].includes(a.q3c)) s1++;
  if (a.q3d === 'c') s2++;
  if (a.q3d === 'a') s1++;
  if (a.q3e === 'd') s2++;
  // Activity 4
  if (a.q4a === 'c') s2 += 2;
  if (a.q4a === 'a') s1 += 2;
  if (a.q4b === 'b') s2 += 2;
  if (a.q4b === 'c') s1++;
  if (['b','d'].includes(a.q4c)) s2 += 2;
  if (a.q4c === 'a') s1++;
  if (['b','c'].includes(a.q4d)) s2++;
  // Activity 5
  if (a.q5a === 'a') s2 += 2;
  if (a.q5a === 'c') s1++;
  if (['b','d'].includes(a.q5b)) s2++;
  if (a.q5b === 'a') s1++;
  if (a.q5c === 'c') s2 += 2;
  if (a.q5c === 'a') s1 += 2;
  if (['b','d'].includes(a.q5d)) s2++;
  if (a.q5d === 'a') s1++;
  // Activity 6
  if (['b','c'].includes(a.q6a)) s2++;
  if (a.q6a === 'a') s1++;
  if (['b','c','d'].includes(a.q6b)) s2++;
  if (a.q6b === 'a') s1++;
  if (['c','d'].includes(a.q6c)) s2 += 2;
  if (['c','d'].includes(a.q6d)) s2++;
  if (a.q6d === 'a') s1++;
  if (a.q6e === 'b') s2 += 2;
  if (a.q6e === 'a') s1++;
  return { s2, s1 };
}

