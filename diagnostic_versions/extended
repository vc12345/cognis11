<script>
// ── STATE ────────────────────────────────────────────────────────────────────
const STORAGE_KEY = 'dud_extended_v1';
const ACT_SECTIONS = ['a1i','a1o','a2i','a2o','a3i','a3o','a4i','a4o','a5i','a5o','a6i','a6o'];
const ALL_SECTIONS = ['cover','resume',...ACT_SECTIONS,'generating','report'];
const ACT_LABELS = {
  'a1i':'Activity 1 · Setup','a1o':'Activity 1 · Observations',
  'a2i':'Activity 2 · Setup','a2o':'Activity 2 · Observations',
  'a3i':'Activity 3 · Setup','a3o':'Activity 3 · Observations',
  'a4i':'Activity 4 · Setup','a4o':'Activity 4 · Observations',
  'a5i':'Activity 5 · Setup','a5o':'Activity 5 · Observations',
  'a6i':'Activity 6 · Setup','a6o':'Activity 6 · Observations',
  'generating':'Generating report…','report':'Your Report'
};
const ACTIVITY_NAMES = [
  'The Rule Switch Game',
  'The Story Maths Game',
  'The Repetition and Pattern Game',
  'The "Why Does That Work?" Game',
  'The Explanation and Narration Game',
  'Rules and Play Observation'
];
const OBS_PAGES = ['a1o','a2o','a3o','a4o','a5o','a6o'];

let state = { childName:'', answers:{}, completedActs:[], currentSection:'cover' };

// ── PERSISTENCE ──────────────────────────────────────────────────────────────
function saveState() {
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); } catch(e){}
}
function loadState() {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    if (raw) { state = {...state, ...JSON.parse(raw)}; return true; }
  } catch(e){}
  return false;
}
function clearAndRestart() {
  if (!confirm('This will erase all your progress and start over. Are you sure?')) return;
  try { localStorage.removeItem(STORAGE_KEY); } catch(e){}
  state = { childName:'', answers:{}, completedActs:[], currentSection:'cover' };
  goTo('cover');
}

// ── NAVIGATION ───────────────────────────────────────────────────────────────
function goTo(id) {
  document.querySelectorAll('.section, #cover, #resume, #generating, #report')
    .forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  state.currentSection = id;
  saveState();

  // Progress
  const idx = ALL_SECTIONS.indexOf(id);
  const pct = idx < 0 ? 0 : Math.round((idx / (ALL_SECTIONS.length - 1)) * 100);
  document.getElementById('progressFill').style.width = pct + '%';
  document.getElementById('navStep').textContent = ACT_LABELS[id] || '';

  // Sticky footer
  const sf = document.getElementById('stickyFoot');
  const si = document.getElementById('stickyInfo');
  if (OBS_PAGES.includes(id)) {
    const n = OBS_PAGES.indexOf(id) + 1;
    si.textContent = `Activity ${n} of 6`;
    sf.style.display = 'flex';
  } else { sf.style.display = 'none'; }

  window.scrollTo({ top: 0, behavior: 'smooth' });
}

// ── ANSWER SELECTION ─────────────────────────────────────────────────────────
function pick(el, qId, val) {
  el.closest('.radio-opts').querySelectorAll('.radio-opt').forEach(o => o.classList.remove('selected'));
  el.classList.add('selected');
  state.answers[qId] = val;
  document.getElementById(qId).classList.remove('error');
}

// ── VALIDATION ───────────────────────────────────────────────────────────────
function validate(sectionId) {
  const section = document.getElementById(sectionId);
  let ok = true;
  section.querySelectorAll('.obs-q[data-req]').forEach(q => {
    if (!state.answers[q.id]) { q.classList.add('error'); ok = false; }
  });
  if (!ok) {
    const first = section.querySelector('.obs-q.error');
    if (first) first.scrollIntoView({ behavior:'smooth', block:'center' });
  }
  return ok;
}

// ── SAVE TOAST ───────────────────────────────────────────────────────────────
function showToast() {
  const t = document.getElementById('saveToast');
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2400);
}

// ── SAVE AND NEXT ────────────────────────────────────────────────────────────
function saveAndNext(currentObs, next, actNum) {
  // collect textarea
  document.querySelectorAll(`#${currentObs} textarea`).forEach(ta => {
    if (ta.name) state.answers[ta.name] = ta.value.trim();
  });
  if (!validate(currentObs)) return;
  if (!state.completedActs.includes(actNum)) state.completedActs.push(actNum);
  saveState();
  showToast();
  goTo(next);
}

// ── START ────────────────────────────────────────────────────────────────────
function startAssessment() {
  const inp = document.getElementById('childInput').value.trim();
  state.childName = inp || 'your child';
  document.getElementById('coverName').textContent = state.childName;
  saveState();
  goTo('a1i');
}

// ── RESTORE ANSWERS ──────────────────────────────────────────────────────────
function restoreAnswers() {
  Object.entries(state.answers).forEach(([qId, val]) => {
    const el = document.getElementById(qId);
    if (!el) {
      // textarea
      const ta = document.querySelector(`textarea[name="${qId}"]`);
      if (ta) ta.value = val;
      return;
    }
    const opt = el.querySelector(`.radio-opt[onclick*="'${val}'"]`);
    if (opt) opt.classList.add('selected');
  });
}

// ── RESUME SCREEN ────────────────────────────────────────────────────────────
function buildResumeScreen() {
  const n = state.childName || 'your child';
  document.getElementById('resumeH').textContent = `Continue ${n}'s assessment`;
  document.getElementById('resumeSub').textContent =
    `You've completed ${state.completedActs.length} of 6 activities. Pick up exactly where you left off.`;

  const actsEl = document.getElementById('resumeActs');
  actsEl.innerHTML = '';
  ACTIVITY_NAMES.forEach((name, i) => {
    const actNum = i + 1;
    const done = state.completedActs.includes(actNum);
    const current = !done && (actNum === state.completedActs.length + 1 || state.completedActs.length === 0 && actNum === 1);
    const div = document.createElement('div');
    div.className = `resume-act ${done ? 'done-act' : current ? 'current-act' : ''}`;
    div.innerHTML = `<div class="resume-act-dot ${done ? 'done' : current ? 'current' : 'todo'}"></div>${actNum}. ${name}${done ? ' ✓' : current ? ' ← continue here' : ''}`;
    actsEl.appendChild(div);
  });

  // Determine where to resume
  let resumeTarget = 'a1i';
  if (state.completedActs.length >= 6) {
    resumeTarget = 'a6o';
  } else if (state.completedActs.length > 0) {
    const next = state.completedActs.length + 1;
    resumeTarget = `a${next}i`;
  }
  document.getElementById('resumeBtn').onclick = () => goTo(resumeTarget);
}

// ── BOOT ─────────────────────────────────────────────────────────────────────
window.addEventListener('DOMContentLoaded', () => {
  const had = loadState();
  if (had && state.completedActs.length > 0) {
    restoreAnswers();
    buildResumeScreen();
    if (state.childName) document.getElementById('childInput').value = state.childName;
    goTo('resume');
  } else {
    goTo('cover');
  }
});

// ── GENERATE REPORT ──────────────────────────────────────────────────────────
async function generateReport() {
  // collect final textareas
  document.querySelectorAll('#a6o textarea').forEach(ta => {
    if (ta.name) state.answers[ta.name] = ta.value.trim();
  });
  if (!validate('a6o')) return;
  if (!state.completedActs.includes(6)) state.completedActs.push(6);
  saveState();

  goTo('generating');
  const steps = ['gs1','gs2','gs3','gs4','gs5','gs6','gs7'];
  for (let i = 0; i < steps.length; i++) {
    await new Promise(r => setTimeout(r, 700));
    document.getElementById(steps[i]).classList.add('vis');
  }

  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({
        model:'claude-sonnet-4-20250514',
        max_tokens:1000,
        system:`You are writing a personalised cognitive profile report for a parent who has completed a 6-activity home assessment of their child. The assessment identifies whether the child is a "Pattern Recogniser" (fast, automatic, pattern-matching — System 1 dominant) or a "Deep Understander" (constructs understanding before acting — System 2 dominant). Write a warm, precise report that references the specific observations entered. Use the child's name throughout. Never use the terms "System 1" or "System 2" — always say "Pattern Recogniser" or "Deep Understander." The report should feel like it was written specifically for this child, not a template. End with a recommendation for the Classification Speed Programme subscription. Output clean HTML using only: <h2>, <h3>, <p>, <ul>, <li>, <strong>. No markdown, no preamble, no extra tags.`,
        messages:[{ role:'user', content: buildPrompt() }]
      })
    });
    const data = await res.json();
    const html = data.content.map(b => b.text||'').join('');
    renderReport(html);
  } catch(e) {
    renderReport(fallback());
  }
}

